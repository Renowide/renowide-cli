# Dependencies
node_modules/

# Build output (compiled and published to npm; not committed)
dist/

# Env / secrets — never commit
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Local caches
.cache/
.tsbuildinfo
*.tsbuildinfo

# Coverage
coverage/

# Python virtualenvs + build artefacts (renowide-canvas)
.venv/
__pycache__/
*.egg-info/
.pytest_cache/
python/**/dist/

# Local runtime credentials accidentally copied into the repo
.renowide/
renowide-credentials*
.npmrc
