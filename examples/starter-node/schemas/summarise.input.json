{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SummariseInput",
  "type": "object",
  "required": ["text"],
  "properties": {
    "text": {
      "type": "string",
      "minLength": 1,
      "description": "Source text to summarise."
    },
    "max_bullets": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 7
    }
  },
  "additionalProperties": false
}
