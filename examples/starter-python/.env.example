# Renowide creator API key — create one at https://renowide.com/creator/api-keys
# or run `npx @renowide/cli login` to generate and persist one automatically.
RENOWIDE_CREATOR_API_KEY=

# Shared secret Renowide sends on every inbound webhook. Generated at
# registration — store the value the CLI prints after `publish`.
RENOWIDE_WEBHOOK_SECRET=

# Where your MCP server listens (used only by the sandbox runner).
PORT=8787
