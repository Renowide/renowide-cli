{
  "name": "@renowide/mcp-server",
  "version": "0.2.3",
  "description": "Model Context Protocol server that lets AI coding assistants (Cursor, Claude Code, Claude Desktop) scaffold, validate, preview, and deploy agents to Renowide as tool calls. The 'build-and-distribute' default: an AI assistant can ship a paying agent on Renowide in two tool calls.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "renowide-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "renowide",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "cursor",
    "claude",
    "claude-code",
    "deployment",
    "canvas-kit"
  ],
  "author": "Renowide",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Renowide/renowide-cli.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://renowide.com/build",
  "bugs": {
    "url": "https://github.com/Renowide/renowide-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@renowide/types": "0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
