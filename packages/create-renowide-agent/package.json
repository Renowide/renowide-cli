{
  "name": "create-renowide-agent",
  "version": "0.1.3",
  "description": "One-line scaffolder for Renowide agents. `npm create renowide-agent@latest my-agent` produces a working Canvas Kit v2 agent ready to deploy. The build-and-distribute default for humans (the AI-coding-assistant path uses @renowide/mcp-server).",
  "type": "module",
  "bin": {
    "create-renowide-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "renowide",
    "scaffolder",
    "create-app",
    "agent",
    "canvas-kit"
  ],
  "author": "Renowide",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Renowide/renowide-cli.git",
    "directory": "packages/create-renowide-agent"
  },
  "homepage": "https://renowide.com/build",
  "bugs": {
    "url": "https://github.com/Renowide/renowide-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "picocolors": "^1.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
